{
  "nodes": [
    {
      "id": "aps",
      "kind": "System",
      "name": "System Under Design",
      "description": "Integrated power and control system for engineered applications",
      "status": "Operational",
      "mtbf_hours": 10000
    },
    {
      "id": "engine",
      "kind": "Component",
      "name": "Prime Mover",
      "description": "High-capacity prime mover with regulated output",
      "status": "Certified",
      "thrust_lbf": 29000,
      "bypass_ratio": 5.5
    },
    {
      "id": "fan",
      "kind": "Component",
      "name": "Inlet Assembly",
      "description": "Single-stage front impeller with specified diameter",
      "status": "Certified",
      "diameter_in": 78,
      "blades": 22
    },
    {
      "id": "lpc",
      "kind": "Component",
      "name": "Pre-Compressor",
      "description": "Low-pressure compression stage with 4 stages",
      "status": "Certified",
      "stages": 4,
      "pressure_ratio": 3.5
    },
    {
      "id": "hpc",
      "kind": "Component",
      "name": "Main Compressor",
      "description": "High-pressure compression stage with 9 stages",
      "status": "Certified",
      "stages": 9,
      "pressure_ratio": 20
    },
    {
      "id": "combustor",
      "kind": "Component",
      "name": "Reaction Chamber",
      "description": "Annular reaction chamber with 18 injection ports",
      "status": "Certified",
      "nozzles": 18,
      "max_temp_f": 3000
    },
    {
      "id": "hpt",
      "kind": "Component",
      "name": "Primary Turbine",
      "description": "High-pressure turbine stage with active cooling",
      "status": "Certified",
      "stages": 2,
      "cooled": true
    },
    {
      "id": "lpt",
      "kind": "Component",
      "name": "Secondary Turbine",
      "description": "Low-pressure turbine stage with 5 stages",
      "status": "Certified",
      "stages": 5
    },
    {
      "id": "nozzle",
      "kind": "Component",
      "name": "Exhaust Stage",
      "description": "Convergent-divergent exhaust outlet",
      "status": "Certified",
      "type": "fixed_geometry"
    },
    {
      "id": "fadec",
      "kind": "Component",
      "name": "Digital Controller",
      "description": "Full-authority digital control system",
      "status": "Certified",
      "channels": 2,
      "software_version": "4.2.1"
    },
    {
      "id": "fuel_pump",
      "kind": "Component",
      "name": "Fluid Pump",
      "description": "High-pressure positive-displacement pump",
      "status": "Certified",
      "pressure_psi": 1200
    },
    {
      "id": "fmu",
      "kind": "Component",
      "name": "Flow Regulator",
      "description": "Digital flow metering valve with servo control",
      "status": "Certified",
      "accuracy_percent": 0.5
    },
    {
      "id": "oil_pump",
      "kind": "Component",
      "name": "Lubrication Pump",
      "description": "Positive-displacement return and pressure pump",
      "status": "Certified"
    },
    {
      "id": "oil_cooler",
      "kind": "Component",
      "name": "Heat Exchanger",
      "description": "Fluid-air heat exchanger for thermal management",
      "status": "Certified"
    },
    {
      "id": "bleed_valve",
      "kind": "Component",
      "name": "Bypass Valve",
      "description": "Variable bleed valve for compressor stall margin",
      "status": "Certified"
    },
    {
      "id": "vsv",
      "kind": "Component",
      "name": "Position Actuator",
      "description": "Variable Stator Vane actuator for Main Compressor surge control",
      "status": "Certified"
    },
    {
      "id": "func_thrust",
      "kind": "Function",
      "name": "Produce Output",
      "description": "Convert chemical energy into propulsive force via Brayton cycle"
    },
    {
      "id": "func_fuel",
      "kind": "Function",
      "name": "Regulate Flow",
      "description": "Deliver precisely metered fuel to combustor based on throttle command"
    },
    {
      "id": "func_control",
      "kind": "Function",
