      "priority": "Critical",
      "verification": "Ground test cell measurement"
    },
    {
      "id": "req_sfc",
      "kind": "Requirement",
      "name": "REQ-002 Efficiency",
      "text": "Specific consumption shall not exceed rated limit at steady state",
      "priority": "High",
      "verification": "Flight test instrumentation"
    },
    {
      "id": "req_tbo",
      "kind": "Requirement",
      "name": "REQ-003 Time Between Overhauls",
      "text": "Time between overhauls shall exceed 10,000 flight hours",
      "priority": "High",
      "verification": "Fleet operational data"
    },
    {
      "id": "req_dispatch",
      "kind": "Requirement",
      "name": "REQ-004 Availability",
      "text": "System shall achieve 99.99% operational availability",
      "priority": "Critical",
      "verification": "Airline reported metrics"
    },
    {
      "id": "req_containment",
      "kind": "Requirement",
      "name": "REQ-005 Containment",
      "text": "Component release event shall not penetrate containment boundary",
      "priority": "Critical",
      "verification": "Blade-out rig test"
    },
    {
      "id": "req_egt",
      "kind": "Requirement",
      "name": "REQ-006 Process Temperature Limit",
